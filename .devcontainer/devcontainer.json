{
    "name": "Peliculapp - Laravel",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/peliculapp",
    "customizations": {
        "vscode": {
            "extensions": [
                "bmewburn.vscode-intelephense-client",
                "amiralizadeh9480.laravel-extra-intellisense",
                "ms-azuretools.vscode-docker",
                "eamodio.gitlens"
            ]
        }
    },
    "postCreateCommand": "git config --global --add safe.directory /peliculapp && composer install && php artisan key:generate && npm install && npm run build && php artisan migrate:fresh --seed",
    "containerEnv": {
        "DB_HOST": "mariadb"
    },
    "forwardPorts": [8000]
}
